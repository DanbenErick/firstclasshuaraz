---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const benefits = [
  { 
    title: 'Calefacción', 
    desc: 'Mantén una temperatura acogedora durante todo tu trayecto, sin importar el clima exterior.', 
    icon: '<path d="M12 9v2m0 4v.01m-6.938-4h.01M18.938 11h.01M15.536 7.5l-.01.01m-7.052 7.05l-.01.01m7.052 0l-.01-.01m-7.052-7.05l-.01-.01M12 21a9 9 0 110-18 9 9 0 010 18z" />'
  },
  { 
    title: 'Aire Acondicionado', 
    desc: 'Frescura garantizada con control climático de última generación para tu máximo confort.', 
    icon: '<path d="M12 2v2m0 16v2M4.93 4.93l1.41 1.41m11.32 11.32l1.41 1.41M2 12h2m16 0h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41" />'
  },
  { 
    title: 'Guía de turismo (bilingüe)', 
    desc: 'Personal experto a tu disposición para enriquecer tu experiencia de viaje en varios idiomas.', 
    icon: '<path d="M17 20h5V4h-5m-6 0H6a2 2 0 00-2 2v12a2 2 0 002 2h5m-2 2h4m-2-2v-4" />'
  },
  { 
    title: 'Mantas y frazadas', 
    desc: 'Textiles premium desinfectados para que tu descanso sea tan cálido como en casa.', 
    icon: '<path d="M4 14a2 2 0 012-2h12a2 2 0 012 2v4a2 2 0 01-2 2H6a2 2 0 01-2-2v-4z M4 10V8a2 2 0 012-2h12a2 2 0 012 2v2" />'
  },
  { 
    title: '145° de reclinación', 
    desc: 'Asientos diseñados ergonómicamente que permiten un ángulo de descanso superior.', 
    icon: '<path d="M4 18v3m16-3v3M4 14h16V6H4v8z M8 14v4m8-4v4" />'
  },
  { 
    title: 'Baños', 
    desc: 'Instalaciones sanitarias impecables a bordo para tu conveniencia.', 
    icon: '<path d="M8 2v3M16 2v3M4 10h16v10a2 2 0 01-2 2H6a2 2 0 01-2-2V10z M12 14v4" />'
  },
];
---

<Layout title="Beneficios | First Class Huaraz">
  <Header />

  <main class="bg-surface-container-lowest">
    
    <!-- ============================================== -->
    <!-- ESTILOS DE ESCRITORIO (Oculto en móvil)         -->
    <!-- ============================================== -->
    
    <!-- Hero / Comodidad Section (Desktop) -->
    <section class="hidden md:flex max-w-7xl mx-auto px-6 lg:px-12 pt-32 pb-24 flex-col lg:flex-row items-center gap-12 lg:gap-20">
      <div class="w-full lg:w-1/2">
        <span class="inline-block bg-primary/10 text-primary font-display font-bold text-[10px] tracking-wider uppercase px-3 py-1.5 rounded-full mb-6">
          EXPERIENCIA PREMIUM
        </span>
        <h1 class="font-display font-bold text-5xl md:text-6xl lg:text-[64px] leading-[1.1] text-primary tracking-tight mb-6">
          Viaja con comodidad
        </h1>
        <p class="font-body text-lg text-on-surface/80 leading-relaxed max-w-lg">
          ¡Disfruta de un viaje placentero con los asientos «Clásicos» y «Semicama» para hacer de tu trayecto una experiencia inolvidable.
        </p>
      </div>
      <div class="w-full lg:w-1/2">
        <div class="relative w-full aspect-[4/3] lg:aspect-[16/10] rounded-3xl overflow-hidden shadow-ambient">
          <img src="" alt="Interior del bus de lujo" class="w-full h-full object-cover bg-surface-container-low" />
        </div>
      </div>
    </section>

    <!-- Benefits Grid Section (Desktop) -->
    <section class="hidden md:block bg-surface-container-low py-20 px-6 lg:px-12">
      <div class="max-w-7xl mx-auto">
        <div class="mb-12">
          <h2 class="font-display font-bold text-4xl text-primary mb-4">Beneficios</h2>
          <div class="w-16 h-1 bg-tertiary"></div>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {benefits.map(benefit => (
            <div class="bg-surface-container-lowest rounded-xl p-8 shadow-sm hover:shadow-ambient transition-shadow duration-300 border border-outline-variant/10 flex flex-col items-start">
              <div class="flex items-center justify-center w-12 h-12 rounded-lg bg-tertiary text-white mb-6">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" set:html={benefit.icon}></svg>
              </div>
              <h3 class="font-display font-bold text-lg text-primary mb-3 leading-tight">{benefit.title}</h3>
              <p class="font-body text-sm text-on-surface/70 leading-relaxed">{benefit.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Detail / Elevamos cada detalle Section (Desktop) -->
    <section class="hidden md:flex max-w-7xl mx-auto px-6 lg:px-12 py-24 flex-col lg:flex-row items-center gap-12 lg:gap-20">
      <div class="w-full lg:w-1/2 order-2 lg:order-1">
        <div class="relative w-full aspect-square md:aspect-[4/3] lg:aspect-square rounded-3xl overflow-hidden shadow-ambient bg-[#111111]">
          <img src="" alt="Asiento ergonómico" class="w-full h-full object-cover mix-blend-lighten" />
        </div>
      </div>
      <div class="w-full lg:w-1/2 order-1 lg:order-2">
        <h2 class="font-display font-bold text-4xl lg:text-5xl leading-tight text-primary tracking-tight mb-6">
          Elevamos cada detalle <br /> del camino
        </h2>
        <p class="font-body text-lg text-on-surface/80 leading-relaxed mb-10 max-w-lg">
          Nuestra flota está equipada con tecnología de punta en suspensión y ergonomía. Cada kilómetro recorrido es una muestra de nuestro compromiso con tu bienestar.
        </p>

        <ul class="space-y-4">
          <li class="flex items-center text-on-surface font-body font-bold text-sm">
            <span class="mr-4 text-tertiary">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>
            </span>
            Mantenimiento riguroso
          </li>
          <li class="flex items-center text-on-surface font-body font-bold text-sm">
            <span class="mr-4 text-tertiary">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>
            </span>
            Protocolos de higiene premium
          </li>
          <li class="flex items-center text-on-surface font-body font-bold text-sm">
            <span class="mr-4 text-tertiary">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>
            </span>
            Soporte 24/7 en ruta
          </li>
        </ul>
      </div>
    </section>

    <!-- ============================================== -->
    <!-- ESTILOS DE MÓVIL (Visible solo en md:hidden) -->
    
    <div class="md:hidden pt-24 px-5 bg-[#F9FAFB] pb-16">
      <!-- Mobile Hero Card -->
      <section class="relative w-full aspect-[4/5] rounded-[24px] overflow-hidden shadow-sm">
        <img src="" class="absolute inset-0 w-full h-full object-cover bg-[#012446]" />
        <div class="absolute inset-0 bg-gradient-to-t from-[#011C38] via-transparent to-transparent z-10"></div>
        <div class="absolute inset-0 bg-black/10 z-10"></div>
        <div class="absolute bottom-8 left-6 right-6 z-20">
           <p class="text-white/80 font-body text-[9px] tracking-widest uppercase mb-1">VIAJA CON COMODIDAD</p>
           <h1 class="text-white font-display font-bold text-3xl">Beneficios</h1>
        </div>
      </section>
      
      <!-- Mobile Quote -->
      <section class="relative z-30 mt-8 mx-2 mb-8">
         <div class="bg-transparent relative">
            <svg class="absolute -top-4 -left-4 text-slate-200 w-16 h-16 z-0" fill="currentColor" viewBox="0 0 24 24"><path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/></svg>
            <p class="relative z-10 font-body italic text-[#4A4A4A] leading-relaxed text-[13px] font-medium pt-2 pl-2">
               ¡Disfruta de un viaje placentero con los asientos «Clásicos» y «Semicama» para hacer de tu trayecto una experiencia inolvidable.
            </p>
         </div>
      </section>

      <!-- Mobile Benefits Grid -->
      <section class="mt-2">
         <div class="grid grid-cols-2 gap-4">
            {benefits.map((benefit, index) => {
               // Tarjeta 145° (Dark Blue, Full Width)
               if(index === 4) {
                 return (
                   <div class="col-span-2 bg-gradient-to-br from-[#0B253D] to-[#123E63] rounded-[20px] p-6 text-white relative overflow-hidden shadow-sm h-36 flex flex-col justify-end mt-2">
                      <div class="absolute right-[-20%] bottom-[-10%] w-48 h-48 bg-white/5 rounded-full blur-2xl"></div>
                      <div class="relative z-10">
                        <div class="flex items-center gap-2 mb-1">
                          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-white/80" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" set:html={benefit.icon}></svg>
                          <h3 class="font-display font-bold text-3xl leading-none tracking-tight">145°</h3>
                        </div>
                        <h4 class="font-display font-bold text-[15px] leading-tight mb-1 text-white">de reclinación</h4>
                        <p class="font-body text-[10px] text-white/60">Máximo descanso para tus rutas largas.</p>
                      </div>
                   </div>
                 )
               }
               // Tarjeta Guia (Blanca, Full Width)
               if(index === 2) {
                 return (
                    <div class="col-span-2 bg-white rounded-[20px] p-5 shadow-sm flex flex-row items-center gap-5 border border-black/[0.03]">
                      <div class="flex items-center justify-center w-12 h-12 rounded-[14px] bg-[#5B3F29] text-[#EBCBAF] shrink-0">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" set:html={benefit.icon}></svg>
                      </div>
                      <div class="flex flex-col">
                        <h3 class="font-display font-extrabold text-[13px] text-[#1C1C1E] leading-tight">{benefit.title}</h3>
                        <p class="font-body text-[10px] text-on-surface/50 mt-1 leading-snug pr-4">Personal capacitado para tu asistencia.</p>
                      </div>
                    </div>
                 )
               }
               
               // Tarjetas Pequeñas Estándar
               return (
                 <div class="bg-white rounded-[20px] p-5 shadow-sm border border-black/[0.03] flex flex-col items-start min-h-[140px] justify-between">
                   <div class="flex items-center justify-center w-[46px] h-[46px] rounded-[14px] bg-[#5B3F29] text-[#EBCBAF]">
                     <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" set:html={benefit.icon}></svg>
                   </div>
                   <h3 class="font-display font-extrabold text-[13px] text-[#1C1C1E] leading-tight mb-1">{benefit.title}</h3>
                 </div>
               )
            })}
         </div>

         <!-- CTA -->
         <button class="w-full mt-8 bg-[#012446] text-white py-4 rounded-[14px] font-display font-bold text-[13px] shadow-md hover:bg-opacity-90 transition-colors tracking-wide">
            Reservar Experiencia
         </button>
      </section>
    </div>

  </main>

  <Footer />
</Layout>
