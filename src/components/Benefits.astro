---
const benefits = [
  { 
    title: 'Calefacción', 
    desc: 'Climatización inteligente.', 
    icon: '<path d="M12 9v2m0 4v.01m-6.938-4h.01M18.938 11h.01M15.536 7.5l-.01.01m-7.052 7.05l-.01.01m7.052 0l-.01-.01m-7.052-7.05l-.01-.01M12 21a9 9 0 110-18 9 9 0 010 18z" />'
  },
  { 
    title: 'Aire Acondicionado', 
    desc: 'Purificación de aire continua.', 
    icon: '<path d="M12 2v2m0 16v2M4.93 4.93l1.41 1.41m11.32 11.32l1.41 1.41M2 12h2m16 0h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41" />'
  },
  { 
    title: 'Guía Bilingüe', 
    desc: 'Expertos en cada ruta.', 
    icon: '<path d="M17 20h5V4h-5m-6 0H6a2 2 0 00-2 2v12a2 2 0 002 2h5m-2 2h4m-2-2v-4" />'
  },
  { 
    title: 'Mantas', 
    desc: 'Material térmico premium.', 
    icon: '<path d="M4 14a2 2 0 012-2h12a2 2 0 012 2v4a2 2 0 01-2 2H6a2 2 0 01-2-2v-4z M4 10V8a2 2 0 012-2h12a2 2 0 012 2v2" />'
  },
  { 
    title: '160° Reclinación', 
    desc: 'Descanso total en tu viaje.', 
    icon: '<path d="M4 18v3m16-3v3M4 14h16V6H4v8z M8 14v4m8-4v4" />' // approximate icon
  },
  { 
    title: 'Baños', 
    desc: 'Servicios higiénicos a bordo.', 
    icon: '<path d="M8 2v3M16 2v3M4 10h16v10a2 2 0 01-2 2H6a2 2 0 01-2-2V10z M12 14v4" />'
  },
];
---

<section id="beneficios" class="py-24 px-6 lg:px-12 bg-surface">
  <div class="max-w-7xl mx-auto flex flex-col lg:flex-row gap-16 items-center">
    
    <!-- Image Side -->
    <div class="w-full lg:w-5/12 relative">
      <div class="relative w-full aspect-[4/5] rounded-3xl overflow-hidden shadow-ambient bg-surface-container-lowest">
        <img 
          src="https://images.unsplash.com/photo-1544620347-c4fd4a3d5957?auto=format&fit=crop&q=80&w=1000" 
          alt="Interior de autobús premium" 
          class="w-full h-full object-cover"
        />
        <!-- 100% Confort Tag -->
        <div class="absolute bottom-6 right-6 bg-primary text-white font-display font-medium px-6 py-4 rounded-xl shadow-lg leading-none">
          <span class="text-xl tracking-tight">100% Confort</span>
        </div>
      </div>
      <!-- Decorative background element / "Ghost Border" hint -->
      <div class="absolute -inset-4 bg-outline-variant/15 rounded-[2rem] -z-10 hidden md:block"></div>
    </div>

    <!-- Content Side -->
    <div class="w-full lg:w-7/12">
      <div class="mb-12">
        <p class="font-display font-bold text-[10px] tracking-[0.1em] text-on-surface/60 uppercase mb-3">Experiencia a bordo</p>
        <h2 class="font-display font-bold text-4xl md:text-5xl text-primary leading-[1.1] tracking-tight">
          Viaja en Primera Clase, <br class="hidden md:block" /> sin importar el camino
        </h2>
      </div>

      <!-- Features Grid -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-x-8 gap-y-10">
        {benefits.map(benefit => (
          <div class="flex items-start">
            <div class="flex-shrink-0 w-12 h-12 bg-tertiary-container rounded-full flex items-center justify-center mr-6 text-on-tertiary-container">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" set:html={benefit.icon}></svg>
            </div>
            <div>
              <h3 class="font-display font-bold text-lg text-on-surface mb-1">{benefit.title}</h3>
              <p class="font-body text-sm text-on-surface/70 leading-relaxed">{benefit.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>

  </div>
</section>
