---
interface Props {
  variant?: 'primary' | 'secondary' | 'tertiary';
  href?: string;
  className?: string;
}

const { variant = 'primary', href, className = '' } = Astro.props;

const baseStyles = "inline-flex items-center justify-center font-body font-semibold transition-all duration-300";
const variants = {
  primary: "bg-primary text-on-primary rounded-xl px-6 py-3 hover:bg-gradient-to-br hover:from-primary hover:to-primary-container shadow-sm hover:shadow-ambient",
  secondary: "bg-surface-container-high rounded-md px-6 py-3 text-on-surface hover:bg-surface-variant",
  tertiary: "text-on-surface underline decoration-primary decoration-2 underline-offset-4 hover:text-primary"
};

const classes = `${baseStyles} ${variants[variant]} ${className}`;
---

{
  href ? (
    <a href={href} class={classes}>
      <slot />
    </a>
  ) : (
    <button class={classes}>
      <slot />
    </button>
  )
}
