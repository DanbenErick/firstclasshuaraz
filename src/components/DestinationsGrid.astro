---
const destinations = [
  { name: 'Lima', subtitle: 'Punto de Partida', img: 'https://images.unsplash.com/photo-1577587230708-1c7f50f68d9f?auto=format&fit=crop&q=80&w=800', span: 'col-span-1 md:col-span-2 lg:col-span-3 min-h-[400px]' },
  { name: 'Laguna 69', subtitle: 'Aventura Glaciar', img: 'https://images.unsplash.com/photo-1544365510-7aa99cffe273?auto=format&fit=crop&q=80&w=1200', span: 'col-span-1 md:col-span-2 lg:col-span-4 min-h-[400px]' },
  { name: 'Llanganuco', subtitle: '', img: 'https://images.unsplash.com/photo-1563212891-b3b050ae1f92?auto=format&fit=crop&q=80&w=600', span: 'col-span-1 md:col-span-1 lg:col-span-2 min-h-[250px]' },
  { name: 'Anta', subtitle: '', img: 'https://images.unsplash.com/photo-1572018850125-9f5e27a6f3b0?auto=format&fit=crop&q=80&w=600', span: 'col-span-1 md:col-span-1 lg:col-span-2 min-h-[250px]' },
  { name: 'Chacas', subtitle: '', img: 'https://images.unsplash.com/photo-1621213032733-4de75be8c5bc?auto=format&fit=crop&q=80&w=600', span: 'col-span-1 md:col-span-1 lg:col-span-2 min-h-[250px]' },
  { name: 'Rocotuyoc', subtitle: '', img: 'https://images.unsplash.com/photo-1469334031218-e382a71b716b?auto=format&fit=crop&q=80&w=600', span: 'col-span-1 md:col-span-1 lg:col-span-1 min-h-[250px]' },
];
---

<section id="destinos" class="py-16 px-6 lg:px-12 bg-surface">
  <div class="max-w-7xl mx-auto">
    
    <!-- Section Header -->
    <div class="flex flex-col md:flex-row md:items-end justify-between mb-12 border-b border-outline-variant/15 pb-6">
      <div>
        <p class="font-display font-bold text-[10px] tracking-[0.1em] text-on-surface/60 uppercase mb-2">Explora lo Inexplorado</p>
        <h2 class="font-display font-bold text-4xl md:text-5xl text-primary tracking-tight">Destinos</h2>
      </div>
      <a href="#" class="mt-4 md:mt-0 font-body text-sm font-semibold text-on-surface hover:text-primary transition-colors flex items-center group">
        Ver todos
        <div class="h-[2px] w-0 bg-primary ml-2 group-hover:w-4 transition-all duration-300"></div>
      </a>
    </div>

    <!-- Grid -->
    <div class="grid grid-cols-1 md:grid-cols-4 lg:grid-cols-7 gap-4 lg:gap-6">
      {destinations.map(dest => (
        <div class={`relative rounded-xl overflow-hidden group bg-surface-container-lowest shadow-ambient ${dest.span} cursor-pointer`}>
          <!-- Image -->
          <div class="absolute inset-0 overflow-hidden">
            <img 
              src={dest.img} 
              alt={dest.name} 
              class="w-full h-full object-cover transform group-hover:scale-105 transition-transform duration-700 ease-out"
            />
          </div>
          <!-- Gradient for text readability at the bottom -->
          <div class="absolute inset-0 bg-gradient-to-t from-[#001730]/90 via-[#001730]/30 to-transparent"></div>
          
          <!-- Content -->
          <div class="absolute bottom-0 left-0 p-6 w-full flex flex-col justify-end">
            <h3 class="font-display font-bold text-2xl text-white tracking-tight">{dest.name}</h3>
            {dest.subtitle && (
              <p class="font-body text-sm text-white/80 mt-1">{dest.subtitle}</p>
            )}
          </div>
        </div>
      ))}
    </div>

  </div>
</section>
